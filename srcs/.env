# ============================================================
#  .ENV - Variables NO sensibles del proyecto Inception
#  Las contraseñas NO van aquí — están en secrets/
#  Este archivo SÍ puede estar en el repo (sin passwords).
# ============================================================

# Dominio del proyecto (debe apuntar a 127.0.0.1 en /etc/hosts)
DOMAIN_NAME=acarranz.42.fr

# ── MariaDB ──────────────────────────────────────────────────
MYSQL_DATABASE=wordpress
MYSQL_USER=delregne

# ── WordPress - Administrador ─────────────────────────────────
# ⚠️  El nombre NO puede contener "admin" ni "administrator"
WP_ADMIN=acarranz
WP_ADMIN_EMAIL=acarranz@inception.42.fr

# ── WordPress - Usuario lector (subscriber) ───────────────────
WP_USER=delregne
WP_USER_EMAIL=delregne@inception.42.fr
WP_USER_PASSWORD=User1234!
LOGIN=acarranz
